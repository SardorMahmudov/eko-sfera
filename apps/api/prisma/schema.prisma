// TOZA HUDUD — Prisma schema
// Geografiya chegaralari GeoJSON sifatida Json ustunlarda saqlanadi (choropleth uchun).
// Koordinatalar oddiy lat/lng float. PostGIS kengaytmasi keyingi spatial query'lar uchun yoqiladi.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ─────────────────────────────  GEOGRAFIYA (spravochnik)  ─────────────────────────────

model Region {
  id        Int        @id @default(autoincrement())
  name      String
  nameLat   String?
  code      String?    @unique
  geojson   Json?
  districts District[]
  companies Company[]
  users     User[]
  createdAt DateTime   @default(now())
}

model District {
  id         Int        @id @default(autoincrement())
  regionId   Int
  region     Region     @relation(fields: [regionId], references: [id])
  name       String
  nameLat    String?
  code       String?
  geojson    Json?
  centerLat  Float?
  centerLng  Float?
  mahallas   Mahalla[]
  polygons   Polygon[]
  companies  Company[]
  companyLinks CompanyDistrict[]
  users      User[]
  createdAt  DateTime   @default(now())

  @@index([regionId])
}

model Mahalla {
  id              Int              @id @default(autoincrement())
  districtId      Int
  district        District         @relation(fields: [districtId], references: [id])
  name            String
  nameLat         String?
  centerLat       Float?
  centerLng       Float?
  streets         Street[]
  subscribers     Subscriber[]
  collectionAreas CollectionArea[]
  visits          Visit[]
  createdAt       DateTime         @default(now())

  @@index([districtId])
}

model Street {
  id        Int     @id @default(autoincrement())
  mahallaId Int
  mahalla   Mahalla @relation(fields: [mahallaId], references: [id])
  name      String
  nameLat   String?

  @@index([mahallaId])
}

// ─────────────────────────────  CHIQINDI INFRATUZILMA  ─────────────────────────────

model Polygon {
  id         Int      @id @default(autoincrement())
  districtId Int
  district   District @relation(fields: [districtId], references: [id])
  name       String
  lat        Float?
  lng        Float?
  areaHa     Float?
  createdAt  DateTime @default(now())

  @@index([districtId])
}

model CollectionArea {
  id        Int      @id @default(autoincrement())
  mahallaId Int
  mahalla   Mahalla  @relation(fields: [mahallaId], references: [id])
  name      String
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())

  @@index([mahallaId])
}

// ─────────────────────────────  KORXONA  ─────────────────────────────

enum CompanyType {
  UNITAR // Davlat Unitar Korxonasi
  KLASTER // Klaster
  PPP // Davlat-xususiy sheriklik
  PRIVATE // Xususiy
}

model Company {
  id              Int               @id @default(autoincrement())
  name            String
  type            CompanyType
  inn             String?
  regionId        Int?
  region          Region?           @relation(fields: [regionId], references: [id])
  districtId      Int?
  district        District?         @relation(fields: [districtId], references: [id])
  accountNumber   String? // korxona hisob raqami
  transitAccount  String? // tranzit hisob raqam
  treasuryAccount String? // korxona g'azna hisob raqami
  mfo             String? // tranzit hisob raqami (MFO)
  contractStart   DateTime?
  contractEnd     DateTime?
  status          String            @default("active")
  serviceDistricts CompanyDistrict[]
  subscribers     Subscriber[]
  vehicles        Vehicle[]
  users           User[]
  createdAt       DateTime          @default(now())

  @@index([regionId])
  @@index([districtId])
}

model CompanyDistrict {
  companyId  Int
  company    Company  @relation(fields: [companyId], references: [id])
  districtId Int
  district   District @relation(fields: [districtId], references: [id])

  @@id([companyId, districtId])
}

// ─────────────────────────────  ABONENT & MOLIYA (mock)  ─────────────────────────────

enum SubscriberType {
  INDIVIDUAL // jismoniy
  LEGAL // yuridik
}

model Subscriber {
  id         Int            @id @default(autoincrement())
  companyId  Int
  company    Company        @relation(fields: [companyId], references: [id])
  mahallaId  Int
  mahalla    Mahalla        @relation(fields: [mahallaId], references: [id])
  fullName   String
  address    String?
  type       SubscriberType @default(INDIVIDUAL)
  balance    Float          @default(0) // musbat = qarzdorlik
  isDebtor   Boolean        @default(false)
  payments   Payment[]
  appeals    Appeal[]
  courtCases CourtCase[]
  acts       Act[]
  createdAt  DateTime       @default(now())

  @@index([companyId])
  @@index([mahallaId])
  @@index([isDebtor])
}

model Payment {
  id           Int        @id @default(autoincrement())
  subscriberId Int
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id])
  amount       Float
  method       String     @default("cash")
  paidAt       DateTime   @default(now())

  @@index([subscriberId])
  @@index([paidAt])
}

model Appeal {
  id           Int        @id @default(autoincrement())
  subscriberId Int
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id])
  text         String
  status       String     @default("new")
  createdAt    DateTime   @default(now())

  @@index([subscriberId])
}

model CourtCase {
  id           Int        @id @default(autoincrement())
  subscriberId Int
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id])
  status       String     @default("open")
  amount       Float?
  createdAt    DateTime   @default(now())

  @@index([subscriberId])
}

model Act {
  id           Int        @id @default(autoincrement())
  subscriberId Int
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id])
  type         String
  createdAt    DateTime   @default(now())

  @@index([subscriberId])
}

// ─────────────────────────────  AVTOPARK / GPS (mock)  ─────────────────────────────

model GpsDevice {
  id        Int      @id @default(autoincrement())
  imei      String   @unique
  type      String // Teltonika FMB920 / Positron MX+ ...
  status    String   @default("active")
  vehicle   Vehicle?
  createdAt DateTime @default(now())
}

model Vehicle {
  id          Int               @id @default(autoincrement())
  companyId   Int
  company     Company           @relation(fields: [companyId], references: [id])
  plateNumber String
  model       String
  vehicleType String // KOMPAKTOR / HOWO / ISUZU ...
  gpsDeviceId Int?              @unique
  gpsDevice   GpsDevice?        @relation(fields: [gpsDeviceId], references: [id])
  visits      Visit[]
  positions   VehiclePosition[]
  createdAt   DateTime          @default(now())

  @@index([companyId])
}

model Visit {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  mahallaId Int
  mahalla   Mahalla  @relation(fields: [mahallaId], references: [id])
  visitedAt DateTime @default(now())

  @@index([vehicleId])
  @@index([mahallaId])
  @@index([visitedAt])
}

model VehiclePosition {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  lat       Float
  lng       Float
  speed     Float    @default(0)
  heading   Float    @default(0)
  ts        DateTime @default(now())

  @@index([vehicleId])
  @@index([ts])
}

// ─────────────────────────────  FOYDALANUVCHI / RBAC  ─────────────────────────────

enum UserRole {
  SUPER_ADMIN
  REGION_ADMIN
  DISTRICT_ADMIN
  COMPANY_OPERATOR
  VIEWER
}

model User {
  id           Int       @id @default(autoincrement())
  fullName     String
  phone        String    @unique
  passwordHash String
  role         UserRole  @default(VIEWER)
  regionId     Int?
  region       Region?   @relation(fields: [regionId], references: [id])
  districtId   Int?
  district     District?  @relation(fields: [districtId], references: [id])
  companyId    Int?
  company      Company?   @relation(fields: [companyId], references: [id])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
}

// ─────────────────────────────  KPI kartalar sozlamasi  ─────────────────────────────

model KpiCard {
  id       Int     @id @default(autoincrement())
  key      String  @unique
  titleUz  String
  icon     String?
  visible  Boolean @default(true)
  sortOrder Int    @default(0)
}
